{
  "name": "@JamesB0010/portfolio-website-react-gen-image-components-plugin",
  "version": "1.0.5",
  "description": "Webpack plugin that generates image component files from a folder of assets.",
  "homepage": "https://github.com/JamesB0010/portfolio-website--react-gen-image-components-plugin.ts#readme",
  "bugs": {
    "url": "https://github.com/JamesB0010/portfolio-website--react-gen-image-components-plugin.ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JamesB0010/portfolio-website--react-gen-image-components-plugin.ts.git"
  },
  "license": "ISC",
  "author": "JamesB0010",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "tsc --watch",
    "build": "npm run build:types && node build.mjs",
    "build:types": "tsc --emitDeclarationOnly",
    "prepack": "npm run build",
    "test": "exit 0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2"
  },
  "dependencies": {
    "@types/node": "^26.0.1",
    "fast-glob": "^3.3.3"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
